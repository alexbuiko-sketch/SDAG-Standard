# Simulation: MoE Routing Entropy & Latency Variance (TTFT)
This notebook demonstrates the SDAG hypothesis: how **Routing Entropy** (expert imbalance and safety overhead) translates into observable **Black-Box signals** like TTFT drift and P99 latency jitter.

**Hypothesis:** As routing entropy increases, the inference pipeline pressure leads to non-linear latency spikes, even if average GPU utilization remains constant.
import numpy as np
import matplotlib.pyplot as plt
import scipy.stats as stats

# Set seed for reproducibility
np.random.seed(42)

def simulate_inference_latency(n_requests=1000, entropy_level=0.05):
    """
    Simulates TTFT (Time To First Token) based on SDAG ECC formula.
    entropy_level (eta): 0.0 (Perfect Efficiency) to 1.0 (High Friction)
    """
    # Baseline latency (theoretical forward pass) in ms
    base_latency = 50 
    
    # 1. Routing Entropy (eta): Increases mean and variance
    # At hyperscale, routing imbalance follows a Gamma distribution (tail latency)
    routing_noise = np.random.gamma(shape=2, scale=entropy_level * 10, size=n_requests)
    
    # 2. Safety Validation Overhead (sigma)
    # Recursive passes add discrete jumps in latency
    safety_overhead = np.random.choice([0, 5, 15], size=n_requests, p=[0.8, 0.15, 0.05])
    
    # Effective Latency Calculation
    effective_latency = base_latency + routing_noise + safety_overhead
    
    return effective_latency

# Generate data for two scenarios
baseline = simulate_inference_latency(entropy_level=0.02)  # Healthy Cluster
high_entropy = simulate_inference_latency(entropy_level=0.15) # SDAG Warning State

plt.figure(figsize=(12, 6))

plt.hist(baseline, bins=50, alpha=0.6, label='Baseline (2% Entropy)', color='green')
plt.hist(high_entropy, bins=50, alpha=0.6, label='SDAG Warning (15% Entropy)', color='red')

plt.title("The 'Semantic Gap': TTFT Distribution Shift under Routing Entropy")
plt.xlabel("Latency (TTFT) in ms")
plt.ylabel("Frequency")
plt.axvline(np.percentile(high_entropy, 99), color='darkred', linestyle='--', label='P99 Tail (High Entropy)')
plt.legend()
plt.grid(axis='y', alpha=0.3)
plt.show()

def estimate_mtbf_degradation(temp_increase_c):
    """
    Simplified Arrhenius-inspired model for MTBF impact.
    Ea (Activation Energy) ~ 0.7 eV
    """
    # Every 10C increase roughly halves the MTTF
    degradation_factor = 2 ** (temp_increase_c / 10)
    return 100 / degradation_factor # Return % of nominal life

# Assume 15% entropy causes a localized 8°C spike in power density
print(f"Estimated Hardware Life Expectancy: {estimate_mtbf_degradation(8):.2f}% of nominal")
